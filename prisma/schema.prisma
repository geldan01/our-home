// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  hashedPassword String
  role           Role     @default(MEMBER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdTodoLists    TodoList[]               @relation("CreatedTodoLists")
  createdTodoItems    TodoItem[]               @relation("CreatedTodoItems")
  todoListPreferences UserTodoListPreference[]
  createdMeals        Meal[]                   @relation("CreatedMeals")
  mealRatings         MealRating[]             @relation("MealRatings")
  addedMealPlanEntries MealPlanEntry[]          @relation("AddedMealPlanEntries")
  tvShowRatings        TvShowRating[]           @relation("TvShowRatings")
  watchedEpisodes      WatchedEpisode[]         @relation("WatchedEpisodes")
  ownedTvShows         TvShow[]                 @relation("OwnedTvShows")
}

model TodoList {
  id          String                   @id @default(cuid())
  name        String
  createdById String
  createdBy   User                     @relation("CreatedTodoLists", fields: [createdById], references: [id])
  items       TodoItem[]
  preferences UserTodoListPreference[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
}

model TodoItem {
  id          String   @id @default(cuid())
  text        String
  done        Boolean  @default(false)
  position    Int      @default(0)
  listId      String
  list        TodoList @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("CreatedTodoItems", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserTodoListPreference {
  id              String   @id @default(cuid())
  showOnDashboard Boolean  @default(true)
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  listId          String
  list            TodoList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([userId, listId])
}

model Meal {
  id          String       @id @default(cuid())
  name        String
  recipe      String?      @db.Text
  imageUrl    String?
  createdById String
  createdBy   User         @relation("CreatedMeals", fields: [createdById], references: [id])
  tags        MealTag[]
  ratings     MealRating[]
  ingredients MealIngredient[]
  planEntries MealPlanEntry[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model MealTag {
  id    String @id @default(cuid())
  name  String @unique
  meals Meal[]
}

model MealRating {
  id     String @id @default(cuid())
  rating Int
  mealId String
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("MealRatings", fields: [userId], references: [id])

  @@unique([mealId, userId])
}

model Ingredient {
  id        String          @id @default(cuid())
  name      String          @unique
  tags      IngredientTag[]
  usages    MealIngredient[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model IngredientTag {
  id          String       @id @default(cuid())
  name        String       @unique
  ingredients Ingredient[]
}

model MealIngredient {
  id           String      @id @default(cuid())
  name         String
  quantity     String?
  mealId       String
  meal         Meal        @relation(fields: [mealId], references: [id], onDelete: Cascade)
  ingredientId String?
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
  position     Int         @default(0)
}

model MealPlanEntry {
  id     String   @id @default(cuid())
  date   DateTime @db.Date
  mealId String
  meal   Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  addedById String
  addedBy   User   @relation("AddedMealPlanEntries", fields: [addedById], references: [id])
  createdAt DateTime @default(now())

  @@unique([date, mealId])
}

enum TvShowStatus {
  WATCHING
  PAUSED
  COMPLETED
  DROPPED
  PLAN_TO_WATCH
}

enum WatchMode {
  INDIVIDUAL
  HOUSEHOLD
}

model Channel {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shows TvShow[]
}

model TvShow {
  id          String       @id @default(cuid())
  tmdbId      Int          @unique
  imdbId      String?
  name        String
  overview    String?      @db.Text
  posterPath  String?
  backdropPath String?
  status      TvShowStatus @default(PLAN_TO_WATCH)
  watchMode   WatchMode    @default(HOUSEHOLD)
  ownerId     String?
  owner       User?        @relation("OwnedTvShows", fields: [ownerId], references: [id], onDelete: SetNull)
  tmdbRating  Float?
  imdbRating  Float?
  firstAirDate DateTime?
  channelId   String?
  channel     Channel?     @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  seasons  TvSeason[]
  ratings  TvShowRating[]
}

model TvSeason {
  id           String    @id @default(cuid())
  tmdbId       Int?
  showId       String
  show         TvShow    @relation(fields: [showId], references: [id], onDelete: Cascade)
  seasonNumber Int
  name         String?
  overview     String?   @db.Text
  posterPath   String?
  airDate      DateTime?
  episodeCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  episodes TvEpisode[]

  @@unique([showId, seasonNumber])
}

model TvEpisode {
  id            String    @id @default(cuid())
  tmdbId        Int?
  seasonId      String
  season        TvSeason  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  episodeNumber Int
  name          String?
  overview      String?   @db.Text
  airDate       DateTime?
  tmdbRating    Float?
  stillPath     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  watchedBy WatchedEpisode[]

  @@unique([seasonId, episodeNumber])
}

model TvShowRating {
  id     String @id @default(cuid())
  rating Int
  showId String
  show   TvShow @relation(fields: [showId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("TvShowRatings", fields: [userId], references: [id])

  @@unique([showId, userId])
}

model WatchedEpisode {
  id        String    @id @default(cuid())
  episodeId String
  episode   TvEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation("WatchedEpisodes", fields: [userId], references: [id])
  watchedAt DateTime  @default(now())

  @@unique([episodeId, userId])
}

model WeatherCity {
  id        String   @id @default(cuid())
  name      String
  country   String
  latitude  Float
  longitude Float
  timezone  String
  isPrimary Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
